---
layout: base
title: "Dissimilar Span Detection (DSD)"

---

<div class="d-hero min-h-screen overflow-hidden relative">
  <img
    src="assets/img/bg_light.png"
    alt="Background"
    class="visible dark:invisible blur-md opacity-60 rotate-345 absolute inset-x-0 top-60 md:-top-5 xl:-top-60 scale-180 md:scale-150 xl:scale-90"
  />
  <img
    src="assets/img/bg_dark.png"
    alt="Background"
    class="invisible dark:visible blur-md opacity-60 rotate-345 absolute inset-x-0 top-60 md:-top-5 xl:-top-60 scale-180 md:scale-150 xl:scale-90"
  />
  <div class="d-hero-overlay bg-base-100 dark:bg-base-300"></div>
  <div class="d-hero-content text-neutral-content text-center -mt-12">
    <div class="max-w-2xl prose">
      <h1 class="mb-8 text-base-content text-4xl sm:text-5xl font-extrabold">
        {{ paper.title }}
      </h1>
      <p class="flex flex-wrap justify-center mb-6 text-lg">
        {% for author in paper.authors -%}
          <span class="whitespace-nowrap">
            <a href="{{ author.website }}">{{ author.name }}</a>
            <sup>
              {{ author.affiliations.split(",").join(", ") }}
            </sup>
            {%- if author.footnotes %}
              <sup>
                {% for footnote in author.footnotes.split(",") -%}
                  , {{ paper.footnotes[footnote]["symbol"] }}
                {%- endfor %}
              </sup>
            {%- endif %}
            {% if not loop.last -%}
              ,&nbsp;
            {% endif %}
          </span>
        {%- endfor %}
      </p>
      <div class="mb-2">
        {% for number, affiliation in paper.affiliations %}
          <p class="mt-0 mb-0 text-sm">
            <sup>{{ number }}</sup> {{ affiliation }}
          </p>
        {% endfor %}
      </div>
      <div class="mb-12">
        {% for _, footnote in paper.footnotes %}
          <p class="mt-0 mb-0 text-sm">
            <sup>{{ footnote["symbol"] }}</sup> {{ footnote["text"] }}
          </p>
        {% endfor %}
      </div>
      <div class="flex align-bottom justify-center flex-wrap gap-x-10 gap-y-6">
        <a class="cursor-default no-underline">
          <div class="d-indicator">
            <span class="d-indicator-item d-badge d-badge-secondary">Soon</span>
            <button class="d-btn d-btn-lg w-35 d-btn-primary d-btn-disabled rounded-full font-semibold">
              <svg
                class="size-[1.2em]"
                viewBox="0 0 24 24"
                stroke-width="1.7"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                color="currentColor"
              >
                <path
                  d="M4 21.4V2.6C4 2.26863 4.26863 2 4.6 2H16.2515C16.4106 2 16.5632 2.06321 16.6757 2.17574L19.8243 5.32426C19.9368 5.43679 20 5.5894 20 5.74853V21.4C20 21.7314 19.7314 22 19.4 22H4.6C4.26863 22 4 21.7314 4 21.4Z"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <path
                  d="M8 10L16 10"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <path
                  d="M8 18L16 18"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <path
                  d="M8 14L12 14"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <path
                  d="M16 2V5.4C16 5.73137 16.2686 6 16.6 6H20"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
              </svg>
              Paper
            </button>
          </div>
        </a>
        <a
          href="https://huggingface.co/datasets/tum-nlp/span-similarity-dataset"
        >
          <button class="d-btn d-btn-lg w-35 d-btn-primary rounded-full font-semibold">
            <svg
              class="size-[1.2em]"
              stroke-width="1.9"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              color="currentColor"
            >
              <path
                d="M3.6 3H20.4C20.7314 3 21 3.26863 21 3.6V20.4C21 20.7314 20.7314 21 20.4 21H3.6C3.26863 21 3 20.7314 3 20.4V3.6C3 3.26863 3.26863 3 3.6 3Z"
                stroke="currentColor"
                stroke-width="1.9"
              >
              </path>
              <path
                d="M9.75 9.75V21"
                stroke="currentColor"
                stroke-width="1.9"
              >
              </path>
              <path d="M3 9.75H21" stroke="currentColor" stroke-width="1.9">
              </path>
            </svg>
            Dataset
          </button>
        </a>
        <a href="https://github.com/dmlls/dissimilar-span-detection">
          <button class="d-btn d-btn-lg w-35 d-btn-primary rounded-full font-semibold">
            <svg
              class="size-[1.2em]"
              stroke-width="1.7"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              color="currentColor"
            >
              <path
                d="M16 22.0268V19.1568C16.0375 18.68 15.9731 18.2006 15.811 17.7506C15.6489 17.3006 15.3929 16.8902 15.06 16.5468C18.2 16.1968 21.5 15.0068 21.5 9.54679C21.4997 8.15062 20.9627 6.80799 20 5.79679C20.4558 4.5753 20.4236 3.22514 19.91 2.02679C19.91 2.02679 18.73 1.67679 16 3.50679C13.708 2.88561 11.292 2.88561 8.99999 3.50679C6.26999 1.67679 5.08999 2.02679 5.08999 2.02679C4.57636 3.22514 4.54413 4.5753 4.99999 5.79679C4.03011 6.81549 3.49251 8.17026 3.49999 9.57679C3.49999 14.9968 6.79998 16.1868 9.93998 16.5768C9.61098 16.9168 9.35725 17.3222 9.19529 17.7667C9.03334 18.2112 8.96679 18.6849 8.99999 19.1568V22.0268"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </path>
              <path
                d="M9 20.0267C6 20.9999 3.5 20.0267 2 17.0267"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </path>
            </svg>
            Code
          </button>
        </a>
      </div>
    </div>
  </div>
</div>

<div class="section bg-base-100">
  <h1>Abstract</h1>
  {% renderTemplate "njk,md", paper %}
  {{ abstract }}
  {% endrenderTemplate %}
</div>

<div class="section flex flex-col overflow-hidden bg-base-200 dark:bg-base-300 items-center">
  <h1 class="self-start">The Task</h1>
  {% renderTemplate "njk,md", paper %}
  {{ task }}
  {% endrenderTemplate %}

  <div class="hidden [@media(hover:none)]:flex">
    <p class="flex gap-2 items-center text-sm">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        stroke-width="1.9"
        class="prose h-10"
        viewBox="0 0 24 24"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width=".869"
          d="m9.473 12-.917 1.222a.914.914 0 0 0 .058 1.166l1.73 1.887a.91.91 0 0 0 .673.296h2.113c1.097 0 1.828-.914 1.828-1.828q0 0 0 0v-3.918M13.587 11.086v-.262c0-1.044 1.371-1.044 1.371 0"
        />
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width=".869"
          d="M12.215 11.086v-.784c0-1.045 1.372-1.045 1.372 0v.783M10.844 11.086V9.943c0-1.045 1.371-1.045 1.371 0q0 0 0 0v1.143M10.844 11.086V8.113a.685.685 0 0 0-.686-.684v0a.686.686 0 0 0-.685.685v5.257"
        />
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.448"
          d="M6.06 11.52H.725m0 0 1.83-1.906M.724 11.52l1.83 1.906M17.94 11.52h5.336m0 0-1.83-1.906m1.83 1.906-1.83 1.906"
        />
      </svg>
      Swipe to see more
    </p>
  </div>
  <div class="d-carousel w-5/4 md:w-full my-4 [@media(hover:none)]:my-0">
    <div
      id="slide1"
      class="d-carousel-item relative w-full justify-center items-center"
    >
      <div class="d-mockup-code w-7/9 h-fit *:leading-8 *:hyphens-auto *:m-0 *:py-1 *:overflow-visible *:before:w-auto *:text-wrap *:box-decoration-slice [&_pre]:flex [&_pre]:px-6 sm:[&_pre]:px-8 [&_pre]:mb-2">
        <pre data-prefix="1"><code>On <span class="dissimilar-span">April 15, 2010</span>, the <span class="dissimilar-span">Colorado Court of Appeals</span> dismissed.</code></pre>
        <pre data-prefix="2"><code>On <span class="dissimilar-span">March 15, 2012</span>, the <span class="dissimilar-span">Oregon Court of Appeals</span> dismissed.</code></pre>
        <span class="flex px-8 text-xs">Cosine similarity: 0.74</span>
      </div>
      <div class="absolute left-1 right-1 top-1/2 flex -translate-y-1/2 transform justify-between">
        <a href="#slide3" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❮</a>
        <a href="#slide2" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❯</a>
      </div>
    </div>
    <div
      id="slide2"
      class="d-carousel-item relative w-full justify-center items-center"
    >
      <div class="d-mockup-code w-7/9 h-fit *:leading-8 *:hyphens-auto *:m-0 *:py-1 *:overflow-visible *:before:w-auto *:text-wrap *:box-decoration-slice [&_pre]:flex [&_pre]:px-6 sm:[&_pre]:px-8 [&_pre]:mb-2">
        <pre data-prefix="1"><code>She went on to win a <span class="dissimilar-span">silver medal</span> in the 2024 Olympics.</code></pre>
        <pre data-prefix="2"><code>She went on to win <span class="dissimilar-span">first place</span> in the 2024 Olympics.</code></pre>
        <span class="flex px-8 text-xs">Cosine similarity: 0.91</span>
      </div>
      <div class="absolute left-1 right-1 top-1/2 flex -translate-y-1/2 transform justify-between">
        <a href="#slide1" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❮</a>
        <a href="#slide3" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❯</a>
      </div>
    </div>
    <div
      id="slide3"
      class="d-carousel-item relative w-full justify-center items-center"
    >
      <div class="d-mockup-code w-7/9 h-fit *:leading-8 *:hyphens-auto *:m-0 *:py-1 *:overflow-visible *:before:w-auto *:text-wrap *:box-decoration-slice [&_pre]:flex [&_pre]:px-6 sm:[&_pre]:px-8 [&_pre]:mb-2">
        <pre data-prefix="1"><code>They are all over the legal age, so such behavior is legal.</code></pre>
        <pre data-prefix="2"><code>They are all over 18, so such behavior is not illegal.</code></pre>
        <span class="flex px-8 text-xs">Cosine similarity: 0.88</span>
      </div>
      <div class="absolute left-1 right-1 top-1/2 flex -translate-y-1/2 transform justify-between">
        <a href="#slide2" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❮</a>
        <a href="#slide1" class="block [@media(hover:none)]:hidden d-btn d-btn-circle carousel-btn bg-base-100 content-center"
        >❯</a>
      </div>
    </div>
  </div>
  <p class="text-xs">
    * Cosine similarities obtained with the model <code class="p-0.5"
    >all-MiniLM-L6-v2</code>.
  </p>
  <p>
    The examples above exemplify how relying uniquely on cosine similarity to
    detect dissimilar texts might not be enough. In some cases, texts that
    differ in meaning might report a higher cosine similarity than semantically
    equivalent texts.
  </p>
</div>

<div class="section bg-base-100">
  <h1>Citation</h1>
  <div class="d-card bg-base-200 py-2 px-8 md:py-6 md:px-12 w-full">
    <div class="absolute top-3 right-3">
      <div id="copy-tooltip" class="d-tooltip d-tooltip-left" data-tip="Copy">
        <button id="copy-citation" class="d-btn d-btn-square">
          <svg
            class="size-[1.2em] active"
            stroke-width="1.9"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            color="currentColor"
          >
            <path
              d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z"
              stroke="currentColor"
              stroke-width="1.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
            <path
              d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9"
              stroke="currentColor"
              stroke-width="1.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
          <svg
            class="size-[1.2em] text-success hidden"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            color="currentColor"
          >
            <path
              d="M8.5 4H6C4.89543 4 4 4.89543 4 6V20C4 21.1046 4.89543 22 6 22H12"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
            </path>
            <path
              d="M15.5 4H18C19.1046 4 20 4.89543 20 6V15"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
            </path>
            <path
              d="M8 6.4V4.5C8 4.22386 8.22386 4 8.5 4C8.77614 4 9.00422 3.77604 9.05152 3.50398C9.19968 2.65171 9.77399 1 12 1C14.226 1 14.8003 2.65171 14.9485 3.50398C14.9958 3.77604 15.2239 4 15.5 4C15.7761 4 16 4.22386 16 4.5V6.4C16 6.73137 15.7314 7 15.4 7H8.6C8.26863 7 8 6.73137 8 6.4Z"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
            </path>
            <path
              d="M15.5 20.5L17.5 22.5L22.5 17.5"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </button>
      </div>
    </div>
    <p
      id="citation"
      class="font-mono text-sm overflow-scroll text-nowrap whitespace-pre"
    >
      {%- for cit in paper.citation -%}
        {%- if not loop.first and not loop.last -%}
          &nbsp;&nbsp;{{ cit }},&#10;
        {%- elif loop.first -%}
          {{ cit }},&#10;
        {%- elif loop.last -%}
          {{ cit }}
        {%- endif -%}
      {%- endfor -%}
    </p>
  </div>
</div>

<script src="scripts/copyToClipboard.js"></script>
<script src="scripts/carousel.js"></script>
